# Plasseres som "server.env" ved siden av docker-compose.yml på VM-en.
# Inneholder runtime-config for backend-containeren.

# Async Postgres-driver (asyncpg) - hostnavn må være tjenestenavnet i compose ("db").
# Bruk samme bruker/passord/db-navn som i db.env.
# NB: passordet bør være KUN alfanumerisk - se db.env.example for hvorfor.
DATABASE_URL=postgresql+asyncpg://postgres:bytt-meg@db:5432/utstyrsoversikt

# Genereres med: openssl rand -hex 32
JWT_SECRET_KEY=bytt-meg-til-en-tilfeldig-32-byte-hex-streng
