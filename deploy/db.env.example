# Plasseres som "db.env" ved siden av docker-compose.yml på VM-en.
# Brukes av postgis-containeren ved første oppstart for å lage
# database, bruker og passord. Må matche credentialene i server.env.
#
# VIKTIG: POSTGRES_PASSWORD bør være KUN alfanumerisk (A-Z, a-z, 0-9).
# Spesialtegn som /, +, = blir URL-encoded i DATABASE_URL og bryter
# alembic sin configparser-parsing.
# Generer med: openssl rand -base64 48 | tr -dc 'A-Za-z0-9' | head -c 32

POSTGRES_DB=utstyrsoversikt
POSTGRES_USER=postgres
POSTGRES_PASSWORD=bytt-meg-til-samme-som-POSTGRES_PASSWORD-pa-github
