# Plasseres som "db.env" ved siden av docker-compose.yml på VM-en.
# Brukes av postgis-containeren ved første oppstart for å lage
# database, bruker og passord. Må matche credentialene i server.env.

POSTGRES_DB=gib2db
POSTGRES_USER=app
POSTGRES_PASSWORD=bytt-meg-til-samme-som-POSTGRES_PASSWORD-pa-github
